{
  "name": "depop",
  "description": "Hide stars, followers, and watchers on GitHub",
  "version": "0.0.0.15",
  "manifest_version": 3,
  "homepage_url": "https://github.com/kachick/depop",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "css": [
        "github-patcher.css"
      ],
      "js": [
        "github-patcher.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Toggle depop",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon-sadness-star.png"
    }
  },
  "icons": {
    "128": "icon-sadness-star.png"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'"
  }
}
